---
// Navbar.astro — Sticky navigation with mobile hamburger
import { contact } from '../data/contact.js';

interface Props {
  currentPath?: string;
}

const { currentPath = Astro.url.pathname } = Astro.props;

const navLinks = [
  { href: '/ewaste', label: 'E-Waste' },
  { href: '/itad', label: 'ITAD' },
  { href: '/recycling', label: 'Recycling' },
  { href: '/blog', label: 'Blog' },
  { href: '/faq', label: 'FAQ' },
  { href: '/services', label: 'All Services' },
  { href: '/locations', label: 'Locations' },
];
---

<!-- Topbar Ticker -->
<div id="topbar" role="marquee" aria-label="Important information">
  <div id="ticker-inner">
    <span class="tb-item">✅ Free Bulk Pickup — Kochi &amp; Ernakulam</span>
    <span class="tb-item">🔒 Certificate of Destruction — Every Job</span>
    <span class="tb-item">⚡ DPDP Act 2023 Compliant</span>
    <span class="tb-item">📞 24/7 Service — Call <a href={contact.phoneLink} style="color:inherit;text-decoration:underline">{contact.phoneDisplay}</a></span>
    <span class="tb-item">🏆 Kerala's #1 Certified ITAD &amp; E-Waste Recycler</span>
    <span class="tb-item">💰 Best Laptop &amp; Phone Buyback Prices Kochi</span>
    <span class="tb-item">🏭 KSPCB Authorized Recycler</span>
    <span class="tb-item">🚀 Same-Day Pickup — Infopark &amp; Smart City</span>
    <!-- Duplicate for seamless loop -->
    <span class="tb-item">✅ Free Bulk Pickup — Kochi &amp; Ernakulam</span>
    <span class="tb-item">🔒 Certificate of Destruction — Every Job</span>
    <span class="tb-item">⚡ DPDP Act 2023 Compliant</span>
    <span class="tb-item">📞 24/7 Service — Call {contact.phoneDisplay}</span>
    <span class="tb-item">🏆 Kerala's #1 Certified ITAD &amp; E-Waste Recycler</span>
    <span class="tb-item">💰 Best Laptop &amp; Phone Buyback Prices Kochi</span>
    <span class="tb-item">🏭 KSPCB Authorized Recycler</span>
    <span class="tb-item">🚀 Same-Day Pickup — Infopark &amp; Smart City</span>
  </div>
</div>

<!-- Main Nav -->
<nav id="nav" role="navigation" aria-label="Main navigation">
  <div class="nav-inner">
    <a href="/" class="brand" aria-label="EWaste Kochi - Home">
      <div class="brand-icon" aria-hidden="true">♻️</div>
      <div>
        <div class="brand-name">EWaste Kochi</div>
        <div class="brand-sub">Certified ITAD · Kerala</div>
      </div>
    </a>

    <nav class="nav-links" aria-label="Site navigation">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={currentPath.startsWith(link.href) ? 'nav-active' : ''}
        >
          {link.label}
        </a>
      ))}
      <a href={contact.phoneLink} class="nav-wa" aria-label="Call us 24/7">📞 Call 24/7</a>
      <a href="/contact" class="nav-cta" id="nav-quote-btn">Get Free Quote →</a>
    </nav>

    <button
      class="hamburger"
      aria-label="Open menu"
      onclick="toggleNav()"
      aria-expanded="false"
      id="ham-btn"
    >
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<!-- Mobile Nav -->
<nav id="mob-nav" role="navigation" aria-label="Mobile navigation" aria-hidden="true">
  {navLinks.map(link => (
    <a href={link.href}>
      {link.label}
    </a>
  ))}
  <a href={contact.phoneLink}>📞 Call 24/7</a>
  <a href="/contact" class="mob-cta">Get Free Quote →</a>
</nav>

<style>
  /* Topbar */
  #topbar { background: var(--green); padding: 9px 0; overflow: hidden; }
  #ticker-inner { display: flex; white-space: nowrap; animation: ticker 40s linear infinite; }
  .tb-item { display: inline-flex; align-items: center; gap: 6px; font-size: .7rem; font-weight: 700; color: #051008; padding: 0 32px; }
  .tb-item::after { content: '◆'; margin-left: 32px; opacity: .4; font-size: .5rem; }
  @keyframes ticker { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }

  /* Nav */
  #nav { position: sticky; top: 0; z-index: 999; background: rgba(5,9,8,.96); backdrop-filter: blur(20px); border-bottom: 1px solid var(--border); height: 68px; display: flex; align-items: center; transition: all .3s; }
  .nav-inner { display: flex; align-items: center; justify-content: space-between; width: 100%; max-width: 1200px; margin: 0 auto; padding: 0 24px; }
  .brand { display: flex; align-items: center; gap: 12px; }
  .brand-icon { width: 42px; height: 42px; background: var(--green); border-radius: 11px; display: flex; align-items: center; justify-content: center; font-size: 1.3rem; flex-shrink: 0; }
  .brand-name { font-size: 1rem; font-weight: 800; color: var(--white); letter-spacing: -.02em; line-height: 1.15; }
  .brand-sub { font-size: .6rem; color: var(--muted); text-transform: uppercase; letter-spacing: .12em; }
  .nav-links { display: flex; align-items: center; gap: 2px; }
  .nav-links a { font-size: .82rem; font-weight: 600; color: var(--text); padding: 7px 12px; border-radius: 8px; transition: all .2s; white-space: nowrap; }
  .nav-links a:hover, .nav-links a.nav-active { color: var(--green); background: rgba(0,232,150,.06); }
  .nav-links .nav-cta { background: var(--green); color: #051008; padding: 8px 18px; }
  .nav-links .nav-cta:hover { background: var(--green2); color: #051008; }
  .nav-links .nav-wa { color: #25D366; border: 1px solid rgba(37,211,102,.3); padding: 7px 14px; }
  .nav-links .nav-wa:hover { background: rgba(37,211,102,.08); color: #25D366; }
  .hamburger { display: none; flex-direction: column; gap: 5px; cursor: pointer; background: none; border: none; padding: 6px; }
  .hamburger span { width: 22px; height: 1.5px; background: var(--white); border-radius: 1px; display: block; transition: .3s; }
  #mob-nav { display: none; position: fixed; top: 68px; inset: 0; top: 68px; background: rgba(5,9,8,.98); backdrop-filter: blur(20px); z-index: 998; padding: 28px 20px; flex-direction: column; gap: 4px; overflow-y: auto; }
  #mob-nav.open { display: flex; }
  #mob-nav a { color: var(--text); font-size: 1rem; font-weight: 600; padding: 14px 18px; border-radius: 10px; border: 1px solid transparent; transition: .2s; }
  #mob-nav a:hover { color: var(--green); background: rgba(0,232,150,.06); border-color: var(--border); }
  #mob-nav .mob-cta { background: var(--green); color: #051008; border-color: var(--green); margin-top: 8px; }

  @media (max-width: 768px) {
    .nav-links { display: none; }
    .hamburger { display: flex; }
  }
</style>

<script>
  function toggleNav() {
    const nav = document.getElementById('mob-nav');
    const btn = document.getElementById('ham-btn');
    const isOpen = nav.classList.toggle('open');
    btn.setAttribute('aria-expanded', String(isOpen));
    nav.setAttribute('aria-hidden', String(!isOpen));
    document.body.style.overflow = isOpen ? 'hidden' : '';
  }

  // Scroll behavior
  window.addEventListener('scroll', () => {
    const nav = document.getElementById('nav');
    if (window.scrollY > 10) {
      nav.style.boxShadow = '0 4px 24px rgba(0,0,0,.4)';
    } else {
      nav.style.boxShadow = 'none';
    }
  });
</script>
