---
// Footer.astro — Site-wide footer with schema-friendly structure
import { contact } from '../data/contact.js';
import { pillarServices } from '../data/services.js';
import { primaryLocations } from '../data/locations.js';
---

<footer role="contentinfo">
  <div class="wrap">
    <div class="footer-grid">
      <!-- Brand column -->
      <div class="footer-brand">
        <a href="/" class="brand" aria-label="EWaste Kochi Home">
          <div class="brand-icon" aria-hidden="true">♻️</div>
          <div>
            <div class="brand-name">EWaste Kochi</div>
            <div class="brand-sub">Certified ITAD · Kerala</div>
          </div>
        </a>
        <p>Kerala's most trusted certified e-waste recycling and IT Asset Disposition company. KSPCB authorized, EPR compliant, NIST/DoD certified data destruction. Serving Kochi, Ernakulam, and all of Kerala since 2018.</p>
        <div class="footer-badges">
          <span class="fb">✓ KSPCB Authorized</span>
          <span class="fb">✓ NIST 800-88</span>
          <span class="fb">✓ DPDP Act 2023</span>
          <span class="fb">✓ EPR Compliant</span>
        </div>
        <div class="footer-social" aria-label="Social media links">
          <a href={contact.social.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook">FB</a>
          <a href={contact.social.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram">IG</a>
          <a href={contact.social.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">LI</a>
          <a href={contact.social.twitter} target="_blank" rel="noopener noreferrer" aria-label="Twitter/X">𝕏</a>
        </div>
      </div>

      <!-- Services column -->
      <div class="footer-col">
        <h4>Services</h4>
        {pillarServices.slice(0, 7).map(s => (
          <a href={`/services/${s.slug}`}>{s.shortName}</a>
        ))}
        <a href="/services">All Services →</a>
      </div>

      <!-- Locations column -->
      <div class="footer-col">
        <h4>Service Areas</h4>
        {primaryLocations.slice(0, 6).map(l => (
          <a href={`/locations/${l.slug}`}>{l.name}</a>
        ))}
        <a href="/locations">All Locations →</a>
      </div>

      <!-- Contact column -->
      <div class="footer-col">
        <h4>Contact</h4>
        <div class="footer-contact-item">
          <span class="fci-icon">📞</span>
          <a href={contact.phoneLink}>{contact.phoneDisplay}</a>
        </div>
        <div class="footer-contact-item">
          <span class="fci-icon">✉️</span>
          <a href={contact.emailLink}>{contact.email}</a>
        </div>
        <div class="footer-contact-item">
          <span class="fci-icon">💬</span>
          <a href={contact.whatsappMessage} target="_blank" rel="noopener noreferrer">WhatsApp Chat</a>
        </div>
        <div class="footer-address">
          <span class="fci-icon">📍</span>
          <address style="font-style: normal;">
            <a href={contact.address.mapLink} target="_blank" rel="noopener noreferrer">
              {contact.address.full}
            </a>
          </address>
        </div>
        <div class="footer-hours">
          <span class="fci-icon">🕐</span>
          <span>{contact.hours}</span>
        </div>
        <a href="/contact" class="btn btn-primary btn-sm" style="margin-top: 16px;" id="footer-quote-btn">Get Free Quote →</a>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="footer-bottom">
      <p>
        © {new Date().getFullYear()} EWaste Kochi. All rights reserved. |
        <a href={contact.address.mapLink} target="_blank" rel="noopener noreferrer">{contact.address.full}</a>
      </p>
      <div class="footer-schema-links">
        <a href="/privacy-policy">Privacy Policy</a>
        <a href="/terms">Terms of Service</a>
        <a href="/sitemap-index.xml">Sitemap</a>
        <a href="/blog">Blog</a>
        <a href="/guides">Guides</a>
      </div>
    </div>
  </div>
</footer>

<style>
  footer { background: var(--surface); border-top: 1px solid var(--border); padding: 72px 0 32px; }
  .footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1.3fr; gap: 48px; margin-bottom: 48px; }
  .footer-brand .brand { display: flex; align-items: center; gap: 12px; margin-bottom: 16px; }
  .footer-brand .brand-icon { width: 42px; height: 42px; background: var(--green); border-radius: 11px; display: flex; align-items: center; justify-content: center; font-size: 1.3rem; flex-shrink: 0; }
  .footer-brand .brand-name { font-size: 1rem; font-weight: 800; color: var(--white); }
  .footer-brand .brand-sub { font-size: .6rem; color: var(--muted); text-transform: uppercase; letter-spacing: .12em; }
  .footer-brand p { font-size: .83rem; color: var(--muted); line-height: 1.75; margin-bottom: 14px; }
  .footer-badges { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 16px; }
  .fb { font-size: .68rem; font-weight: 700; color: var(--green); background: rgba(0,232,150,.07); border: 1px solid rgba(0,232,150,.15); padding: 3px 9px; border-radius: 12px; }
  .footer-social { display: flex; gap: 10px; }
  .footer-social a { width: 36px; height: 36px; border-radius: 8px; background: var(--card); border: 1px solid var(--border); display: flex; align-items: center; justify-content: center; font-size: .78rem; font-weight: 700; color: var(--muted); transition: all .2s; }
  .footer-social a:hover { border-color: var(--green); color: var(--green); background: rgba(0,232,150,.06); }
  .footer-col h4 { font-size: .78rem; font-weight: 700; color: var(--white); text-transform: uppercase; letter-spacing: .14em; margin-bottom: 16px; }
  .footer-col a { display: block; font-size: .83rem; color: var(--muted); margin-bottom: 8px; transition: color .2s; }
  .footer-col a:hover { color: var(--green); }
  .footer-contact-item, .footer-address, .footer-hours { display: flex; align-items: flex-start; gap: 8px; margin-bottom: 10px; }
  .fci-icon { font-size: .9rem; flex-shrink: 0; margin-top: 1px; }
  .footer-contact-item a, .footer-address a { font-size: .83rem; color: var(--muted); transition: color .2s; }
  .footer-contact-item a:hover, .footer-address a:hover { color: var(--green); }
  .footer-hours span { font-size: .83rem; color: var(--muted); }
  .footer-bottom { border-top: 1px solid var(--border); padding-top: 24px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 12px; }
  .footer-bottom p { font-size: .78rem; color: var(--muted); }
  .footer-bottom p a { color: var(--muted); transition: color .2s; }
  .footer-bottom p a:hover { color: var(--green); }
  .footer-schema-links { display: flex; gap: 16px; flex-wrap: wrap; }
  .footer-schema-links a { font-size: .75rem; color: var(--muted); transition: color .2s; }
  .footer-schema-links a:hover { color: var(--green); }

  @media (max-width: 1024px) {
    .footer-grid { grid-template-columns: 1fr 1fr; gap: 32px; }
    .footer-brand { grid-column: 1 / -1; }
  }
  @media (max-width: 640px) {
    .footer-grid { grid-template-columns: 1fr; }
    .footer-brand { grid-column: auto; }
    .footer-bottom { flex-direction: column; text-align: center; }
    .footer-schema-links { justify-content: center; }
  }
</style>
