---
// src/pages/blog/[slug].astro — Multi-Pillar Blog Post Template
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { blogs, getBlogBySlug, blogCategories } from '../../data/blogs.js';
import { faqs } from '../../data/faqs.js';

export async function getStaticPaths() {
  return blogs.map(blog => ({
    params: { slug: blog.slug },
    props: { blog },
  }));
}

const { blog } = Astro.props;
const category = blogCategories.find(c => c.id === blog.category);

// Programmatic context: Match FAQs related to this blog's category
const relatedFaqs = faqs.filter(f => f.category === blog.category).slice(0, 5);

const breadcrumbs = [
  { name: 'Home', url: 'https://ewastekochi.com/' },
  { name: 'Blog', url: 'https://ewastekochi.com/blog' },
  { name: blog.title, url: `https://ewastekochi.com/blog/${blog.slug}` },
];

const blogSchema = {
  "@type": "BlogPosting",
  "headline": blog.title,
  "description": blog.excerpt,
  "author": { "@type": "Organization", "name": "EWaste Kochi" },
  "datePublished": blog.date,
  "mainEntityOfPage": { "@type": "WebPage", "@id": `https://ewastekochi.com/blog/${blog.slug}` }
};
---

<BaseLayout
  title={`${blog.title} | EWaste Kochi Blog`}
  description={blog.excerpt}
  schema={blogSchema}
  faqs={relatedFaqs}
  breadcrumbs={breadcrumbs}
>
  <Navbar currentPath="/blog" />

  <article class="blog-container" itemscope itemtype="https://schema.org/BlogPosting">
    <header class="blog-header">
      <div class="wrap">
        <div class="blog-meta">
          <span class="blog-cat">{category?.name}</span>
          <span class="blog-date">{blog.date}</span>
        </div>
        <h1 class="blog-h1" itemprop="headline">{blog.title}</h1>
        <p class="blog-excerpt" itemprop="description">{blog.excerpt}</p>
        <div class="blog-author-line">
           By <span itemprop="author">EWaste Kochi Compliance Team</span>
        </div>
      </div>
    </header>

    <div class="wrap">
      <div class="blog-layout">
        <div class="blog-body" itemprop="articleBody">
          <div set:html={blog.content} />

          {relatedFaqs.length > 0 && (
            <div class="post-faqs">
              <h3 class="faq-sub-h">Frequently Asked About {category?.name}</h3>
              <div class="faq-list">
                 {relatedFaqs.map((f, i) => (
                   <div class="faq-item">
                     <strong>Q: {f.q}</strong>
                     <p>A: {f.a}</p>
                   </div>
                 ))}
              </div>
            </div>
          )}
        </div>

        <aside class="blog-sidebar">
          <div class="sidebar-box">
             <h4>Explore Categories</h4>
             <nav class="side-cats">
                {blogCategories.map(cat => (
                  <a href={`/blog/category/${cat.id}`}>{cat.name}</a>
                ))}
             </nav>
          </div>
          
          <div class="sidebar-cta">
             <h4>Ready for disposal?</h4>
             <p>Professional e-waste recycling and ITAD services for Kochi enterprises.</p>
             <a href="/contact" class="btn btn-primary btn-block">Get Free Quote →</a>
          </div>
        </aside>
      </div>
    </div>
  </article>

  <Footer />
</BaseLayout>

<style>
  .blog-header { padding: 100px 0 60px; background: #0A1410; border-bottom: 1px solid var(--border); }
  .blog-meta { display: flex; gap: 15px; margin-bottom: 20px; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--green); }
  .blog-h1 { font-size: clamp(2rem, 5vw, 3rem); line-height: 1.15; margin-bottom: 20px; color: var(--white); }
  .blog-excerpt { font-size: 1.25rem; color: var(--text); font-family: var(--serif); font-style: italic; max-width: 800px; line-height: 1.65; }
  .blog-author-line { margin-top: 25px; font-size: 0.85rem; color: var(--muted); }

  .blog-layout { display: grid; grid-template-columns: 1fr 320px; gap: 60px; padding: 60px 0; }
  .blog-body { font-size: 1.1rem; line-height: 1.95; color: var(--text); font-family: var(--serif); }
  .blog-body h2 { margin: 40px 0 20px; color: var(--white); font-family: var(--font); font-size: 1.8rem; }
  .blog-body h3 { margin: 30px 0 15px; color: var(--white); font-family: var(--font); font-size: 1.4rem; }
  .blog-body p { margin-bottom: 25px; }
  .blog-body strong { color: var(--white); }

  .post-faqs { margin-top: 60px; padding: 40px; background: var(--card); border: 1px solid var(--border2); border-radius: 20px; }
  .faq-sub-h { margin-top: 0 !important; margin-bottom: 25px !important; }
  .faq-item { margin-bottom: 25px; border-bottom: 1px solid var(--border); padding-bottom: 15px; }
  .faq-item:last-child { border-bottom: none; }
  .faq-item strong { display: block; margin-bottom: 8px; color: var(--white); font-size: 1rem; }
  .faq-item p { font-size: 0.9rem; color: var(--text); margin: 0; }

  .sidebar-box { background: var(--card); border: 1px solid var(--border); padding: 25px; border-radius: 15px; margin-bottom: 30px; }
  .sidebar-box h4 { font-size: 0.8rem; text-transform: uppercase; margin-bottom: 15px; color: var(--white); }
  .side-cats { display: flex; flex-direction: column; gap: 8px; }
  .side-cats a { font-size: 0.85rem; color: var(--muted); transition: color 0.2s; }
  .side-cats a:hover { color: var(--green); }

  .sidebar-cta { padding: 30px; background: rgba(0,232,150,0.05); border: 1px solid var(--green3); border-radius: 15px; text-align: center; }
  .sidebar-cta h4 { margin-bottom: 10px; color: var(--white); }
  .sidebar-cta p { font-size: 0.85rem; color: var(--text); margin-bottom: 20px; }

  @media (max-width: 1024px) {
    .blog-layout { grid-template-columns: 1fr; }
    .blog-sidebar { order: 2; }
  }
</style>
