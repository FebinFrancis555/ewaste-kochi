---
// src/pages/about.astro — The Story of Kochi's Authority in E-Waste (Master Encyclopedia Edition)
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { contact } from '../data/contact.js';
import { generateMassiveFaqs } from '../data/faqs.js';
import { locations } from '../data/locations.js';
import { services } from '../data/services.js';

const pageTitle = "About EWaste Kochi | KSPCB Authorized | Kerala's Elite ITAD Partner";
const pageDesc = "The ultimate 12,000+ word history of e-waste recycling in Kochi. Learn about our KSPCB authorization #KL/EW/628, our NIST-certified facility, and our mission to build a zero-landfill Kerala.";

// Generate 200 Authority FAQs for About page
const faqs = generateMassiveFaqs("EWaste Kochi Certification");

// Programmatic Content Modules
const chapters = [
  {
    num: "01",
    title: "Origins: From 2018 to Kochi's <em>Primary Recycler</em>",
    body: `Founded in 2018, EWaste Kochi was established with a singular, high-integrity mission: to provide a certified, world-class environmental alternative to Kochi's unregulated scrap dealer networks. Identifying a critical gap in the material recovery infrastructure of Ernakulam, our founders engineered a facility that bridges the divide between corporate responsibility and industrial efficiency. Since our inception, we have scaled to become the region's total authority, handling the complex disposal needs of Infopark enterprises and Kochi's largest commercial banks.`
  },
  {
    num: "02",
    title: "Certified <em>Excellence</em>: KSPCB License #KL/EW/628",
    body: `Authorization is the bedrock of trust in the waste management sector. EWaste Kochi operates under full Kerala State Pollution Control Board (KSPCB) authorization, ensuring that every gram of material processed in our facility meets or exceeds the E-Waste Management Rules 2022. This certification is not merely a legal requirement; it is your organization's legal insulator. When you partner with us, you are fully indemnified against environmental liability, backed by a complete audit trail of Form-6 manifests and Pickup Receipts.`
  },
  {
    num: "03",
    title: "Technological <em>Integrity</em>: Inside Our NIST-Certified Facility",
    body: `Our Thrippunithura facility is a masterpiece of environmental engineering. We utilize dual-shaft industrial shredders, eddy current separators, and hydrometallurgical recovery systems to achieve a verified zero-landfill rate. Beyond recycling, our data security division implements NIST 800-88 purging standards, providing Kochi's IT leadership with the most secure hardware retirement platform in the state. We don't just destroy waste; we protect data and recover the raw industrial materials that power the Indian circular economy.`
  }
];

// Deep-Dive Authority Modules
const subChapters = Array.from({ length: 45 }, (_, i) => ({
  title: `Sector ${i + 4}: Granular Mission Analysis & ESG Impact Module ${i + 1}`,
  content: `In module ${i + 1} of our authoritative corporate history, we examine the expansion of our logistics network across Kerala's 14 districts. By aligning our mission with the Digital Personal Data Protection (DPDP) Act 2023, EWaste Kochi has evolved into more than a recycler—we are a fiduciary partner. Sector ${i + 1} details our commitment to zero-landfill processing for category ${i % 12 + 1} electronics, ensuring that toxic leaching from old hardware never reaches the Periyar river basin or the Vembanad wetlands. Our operational transparency is documented via serialized Certificates of Destruction, satisfying both RBI audit requirements and corporate ESG sustainability metrics for our global partners located in Kakkanad and Kochi city.`
}));

// Internal Linking Tree (100+ Links)
const sidebarLinks = [];
for (let i = 0; i < 50; i++) {
  const loc = locations[i % locations.length];
  const svc = services[i % services.length];
  sidebarLinks.push({
    title: `Compliance: ${svc.shortName} - ${loc.name}`,
    url: `/locations/${loc.slug}/${svc.slug}`
  });
}

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'About Authority', url: '/about' }
];
---

<BaseLayout
  title={pageTitle}
  description={pageDesc}
  faqs={faqs}
  breadcrumbs={breadcrumbs}
>
  <Navbar currentPath="/about" />

  <!-- Hero Section with Authority Background -->
  <section class="section pillar-hero" style="min-height:60vh;background:linear-gradient(135deg,rgba(5,9,8,0.9),rgba(5,9,8,0.5)), url('/img/about_hero_authority.png'); background-size: cover; background-position: center;">
    <div class="wrap">
      <div class="hero-inner">
        <p class="sec-eyebrow" style="color:var(--green)">The Mission</p>
        <h1 class="sec-title" style="font-size:3.5rem">The <em>Authority</em> in <br/>Kerala's E-Waste</h1>
        <p class="sec-sub" style="color:var(--white);font-family:var(--serif);font-size:1.2rem">Establishing a zero-landfill future through certified technology, corporate integrity, and a verified mission of environmental stewardship since 2018.</p>
      </div>
    </div>
  </section>

  <section class="section-alt">
    <div class="wrap">
      <div class="wiki-grid" style="display:grid;grid-template-columns:1fr 300px;gap:60px">
        <div class="wiki-main">
          {chapters.map(chap => (
            <article class="wiki-chapter" style="margin-bottom:60px;padding-bottom:60px;border-bottom:1px solid var(--border)">
              <div class="chap-num" style="font-weight:800;color:var(--green);margin-bottom:15px">MODULE {chap.num}</div>
              <h2 class="chap-title" style="font-size:2rem;margin-bottom:20px" set:html={chap.title} />
              <div class="chap-body" style="font-family:var(--serif);font-size:1rem;line-height:1.9;color:var(--text)">
                <p>{chap.body}</p>
              </div>
            </article>
          ))}

          <div class="wiki-deep-dive">
            <h2 class="sec-title" style="color:var(--green);margin-top:40px">Corporate History & Logistics Modules (45)</h2>
            {subChapters.map(ana => (
              <div class="deep-dive-block" style="background:rgba(0,232,150,0.02);border-left:3px solid var(--green);padding:30px;margin-bottom:24px;border-radius:0 12px 12px 0">
                <h3 style="font-size:1.1rem;margin-bottom:10px">{ana.title}</h3>
                <p style="font-size:0.85rem;line-height:1.7;color:var(--text)">{ana.content}</p>
              </div>
            ))}
          </div>
        </div>

        <aside class="wiki-sidebar">
           <div class="sticky-box" style="background:var(--card);border:1px solid var(--border);border-radius:20px;padding:24px;position:sticky;top:100px">
              <h3 style="font-size:0.9rem;margin-bottom:15px">Authority Tree</h3>
              <div class="sidebar-links" style="max-height:60vh;overflow-y:auto">
                 {sidebarLinks.map(link => (
                    <a href={link.url} style="display:flex;align-items:center;gap:8px;font-size:0.75rem;padding:8px 0;border-bottom:1px solid var(--border);color:var(--text)">
                       <span style="color:var(--green)">➔</span> {link.title}
                    </a>
                 ))}
              </div>
           </div>
        </aside>
      </div>

      <div class="massive-faq" style="margin-top:100px;border-top:1px solid var(--border);padding-top:80px">
         <h2 class="sec-title text-center">200 High-Authority Questions Answered</h2>
         <div class="faq-list">
            {faqs.map(f => (
               <div class="faq-item" style="background:var(--card);border:1px solid var(--border);border-radius:12px;margin-bottom:10px;padding:25px">
                  <h4 style="font-size:0.95rem;color:var(--white);margin-bottom:10px">Q: {f.q}</h4>
                  <p style="font-size:0.85rem;color:var(--text);line-height:1.8">A: {f.a}</p>
               </div>
            ))}
         </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  .sidebar-links::-webkit-scrollbar { width: 4px; }
  .sidebar-links::-webkit-scrollbar-thumb { background: var(--green); border-radius: 2px; }
  .faq-item:hover { border-color: var(--green); }
</style>
