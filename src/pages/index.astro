---
// src/pages/index.astro — Ultimate Authority Hub Homepage
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { contact } from '../data/contact.js';
import { pillarServices, services } from '../data/services.js';
import { primaryLocations } from '../data/locations.js';
import { testimonials, aggregateRating } from '../data/testimonials.js';
import { generateTopicFaqs } from '../data/faqs.js';

const homeFaqs = generateTopicFaqs("EWaste Kochi");

const howToSchema = {
  '@type': 'HowTo',
  name: 'How to Schedule E-Waste Pickup in Kochi',
  description: 'Certified e-waste collection and ITAD services in Kochi, Kerala',
  step: [
    { '@type': 'HowToStep', position: 1, name: 'Contact', text: `Call us at ${contact.phone}.` },
    { '@type': 'HowToStep', position: 2, name: 'Quote', text: 'Get same-day quote.' },
    { '@type': 'HowToStep', position: 3, name: 'Destruction', text: 'NIST/DoD destruction with CoD.' }
  ],
};
---

<BaseLayout
  title="EWaste Kochi | Certified E-Waste Recycling & ITAD Services Kerala"
  description="Kerala's #1 KSPCB authorized e-waste recycler. Certified ITAD, NIST/DoD data destruction, and free bulk pickup for IT parks, banks, and corporates. Dominate long-tail local SEO."
  faqs={homeFaqs}
  schema={[howToSchema]}
>
  <Navbar currentPath="/" />

  <!-- Hero Section -->
  <section class="hero" id="hero">
    <div class="wrap">
      <div class="hero-inner">
        <div class="hero-content">
          <div class="hero-badge">Award-Winning ITAD & E-Waste Partner</div>
          <h1>Certified <em>E-Waste</em> <br/>& ITAD Kochi</h1>
          <p>The total authority in electronic waste disposal, <a href="/itad">IT asset disposition</a>, and NIST-certified data destruction in Kerala.</p>
          <div class="hero-ctas">
             <a href="/contact" class="btn btn-primary btn-lg">Get Free Quote →</a>
             <a href={contact.phoneLink} class="btn btn-outline btn-lg">📞 Call {contact.phoneDisplay}</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Authority Pillars -->
  <section class="section-alt">
    <div class="wrap">
      <div class="text-center">
        <h2 class="sec-title">The Three <em>Pillars</em> of Authority</h2>
        <p class="sec-sub">Deep-dive into our core compliance and recycling specialized hubs.</p>
      </div>

      <div class="pillar-row-3">
        <a href="/ewaste" class="pillar-card">
          <h3>E-Waste Hub</h3>
          <p>Everything about <a href="/ewaste">E-Waste Rules 2022</a>, hazardous waste, and local disposal laws.</p>
          <span>Explore Authority →</span>
        </a>
        <a href="/itad" class="pillar-card">
          <h3>ITAD Center</h3>
          <p><a href="/itad">Certified ITAD</a>, asset management, and NIST-grade data wiping for Infopark corporations.</p>
          <span>Explore Enterprise →</span>
        </a>
        <a href="/recycling" class="pillar-card">
          <h3>Recycling Tech</h3>
          <p>Deep insight into <a href="/recycling">Zero-Landfill tech</a>, circular economy, and refined material recovery.</p>
          <span>Explore Process →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Massive Services Cluster -->
  <section class="section">
    <div class="wrap">
      <div class="text-center">
        <h2 class="sec-title">17 Specialized <em>Solutions</em></h2>
        <p class="sec-sub">From hard drive shredding to battery stewardship across Kerala.</p>
      </div>
      <div class="home-services-grid">
        {pillarServices.map(svc => (
          <article class="h-svc-card">
            <h3><a href={`/services/${svc.slug}`}>{svc.name}</a></h3>
            <p>{svc.tagline}</p>
          </article>
        ))}
      </div>
      <div class="text-center" style="margin-top: 40px;">
        <a href="/services" class="btn btn-outline">View All Solutions →</a>
      </div>
    </div>
  </section>

  <!-- Massive 50 FAQ Home -->
  <section class="section-alt">
    <div class="wrap">
       <div class="text-center">
          <h2 class="sec-title">50 Mastering FAQs about EWaste Kochi</h2>
          <p class="sec-sub">The ultimate knowledge base for certified electronic disposal in India.</p>
       </div>
       <div class="faq-grid-massive home-faqs">
          {homeFaqs.map(f => (
            <div class="faq-card">
               <h4>{f.q}</h4>
               <p>{f.a}</p>
            </div>
          ))}
       </div>
    </div>
  </section>

  <!-- Locations Deep Interlink -->
  <section class="section">
    <div class="wrap">
      <div class="text-center">
        <h2 class="sec-title">30 Authority <em>Locations</em></h2>
        <p class="sec-sub">We provide free bulk pickup across all Ernakulam and Kerala districts.</p>
      </div>
      <div class="home-loc-grid">
        {primaryLocations.map(l => (
          <a href={`/locations/${l.slug}`} class="h-loc-link">{l.name} →</a>
        ))}
        <a href="/locations" class="h-loc-link all-locs">View All 30 Locations →</a>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  .hero { padding: 15vw 0 10vw; background: radial-gradient(ellipse 65% 80% at 75% 45%, rgba(0,232,150,0.06), transparent 60%); }
  .hero h1 { font-size: clamp(3rem, 7vw, 5rem); line-height: 1; margin-bottom: 25px; }
  .hero p { font-size: 1.35rem; color: var(--text); max-width: 700px; line-height: 1.6; margin-bottom: 40px; }
  .hero-ctas { display: flex; gap: 20px; }
  .hero-badge { display: inline-block; padding: 7px 18px; background: rgba(0,232,150,0.08); border: 1px solid rgba(0,232,150,0.18); border-radius: 20px; color: var(--green); font-size: 0.75rem; font-weight: 800; text-transform: uppercase; margin-bottom: 20px; }

  .pillar-row-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 30px; margin-top: 60px; }
  .pillar-card { background: var(--card); border: 1px solid var(--border); padding: 40px; border-radius: 30px; transition: 0.3s; display: block; }
  .pillar-card:hover { border-color: var(--green); transform: translateY(-5px); }
  .pillar-card h3 { font-size: 1.5rem; color: var(--white); margin-bottom: 15px; }
  .pillar-card p { font-size: 0.9rem; color: var(--text); line-height: 1.6; margin-bottom: 25px; }
  .pillar-card span { font-size: 0.8rem; font-weight: 800; color: var(--green); text-transform: uppercase; }

  .home-services-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 50px; }
  .h-svc-card { padding: 25px; background: var(--card); border: 1px solid var(--border2); border-radius: 15px; }
  .h-svc-card h3 { font-size: 1.05rem; }

  .faq-grid-massive { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 60px; }
  .faq-card { background: var(--card); border: 1px solid var(--border); padding: 25px; border-radius: 15px; }
  .faq-card h4 { font-size: 0.9rem; color: var(--white); line-height: 1.4; margin-bottom: 10px; }
  .faq-card p { font-size: 0.8rem; color: var(--muted); line-height: 1.6; }

  .home-loc-grid { display: flex; flex-wrap: wrap; gap: 15px; justify-content: center; margin-top: 50px; }
  .h-loc-link { padding: 12px 25px; background: var(--card); border: 1px solid var(--border); border-radius: 50px; font-size: 0.9rem; font-weight: 700; color: var(--text); transition: 0.3s; }
  .h-loc-link:hover { border-color: var(--green); color: var(--green); }
  .all-locs { background: var(--green); color: var(--black) !important; border-color: var(--green); }

  @media (max-width: 1024px) {
     .pillar-row-3 { grid-template-columns: 1fr; }
     .faq-grid-massive { grid-template-columns: 1fr 1fr; }
     .home-services-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 768px) {
     .faq-grid-massive { grid-template-columns: 1fr; }
     .home-services-grid { grid-template-columns: 1fr; }
  }
</style>
