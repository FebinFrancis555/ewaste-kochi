---
// BaseLayout.astro — Master layout for all pages
// Injects schema, meta, fonts, and wraps every page
import { contact } from '../data/contact.js';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  schema?: object | object[];
  faqs?: Array<{ q: string; a: string }>;
  breadcrumbs?: Array<{ name: string; url: string }>;
  noIndex?: boolean;
  dateModified?: string;
}

const {
  title,
  description,
  canonical = Astro.url.href,
  ogImage = 'https://ewastekochi.in/assets/images/og-ewastekochi.webp',
  schema,
  faqs = [],
  breadcrumbs = [{ name: 'Home', url: 'https://ewastekochi.in/' }],
  noIndex = false,
  dateModified = new Date().toISOString().split('T')[0],
} = Astro.props;

// Build FAQ schema if provided
const faqSchema = faqs.length > 0 ? {
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
} : null;

// Build full JSON-LD graph
const baseSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': ['LocalBusiness', 'RecyclingCenter', 'ProfessionalService'],
      '@id': 'https://ewastekochi.in/#organization',
      name: 'EWaste Kochi',
      alternateName: ['EWaste Kochi ITAD', 'EWasteKochi', 'Kochi E-Waste Recycling'],
      url: 'https://ewastekochi.in/',
      logo: {
        '@type': 'ImageObject',
        url: 'https://ewastekochi.in/assets/images/logo.webp',
        width: 200,
        height: 60,
      },
      image: 'https://ewastekochi.in/assets/images/facility.webp',
      telephone: contact.phone,
      email: contact.email,
      foundingDate: contact.founded,
      address: {
        '@type': 'PostalAddress',
        streetAddress: contact.address.street,
        addressLocality: contact.address.city,
        addressRegion: 'Kerala',
        postalCode: contact.address.pincode,
        addressCountry: 'IN',
      },
      geo: {
        '@type': 'GeoCoordinates',
        latitude: 9.9390,
        longitude: 76.3590,
      },
      openingHoursSpecification: [
        {
          '@type': 'OpeningHoursSpecification',
          dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'],
          opens: '00:00',
          closes: '23:59',
        },
      ],
      aggregateRating: {
        '@type': 'AggregateRating',
        ratingValue: '4.9',
        reviewCount: '127',
        bestRating: '5',
        worstRating: '1',
      },
      sameAs: Object.values(contact.social),
    },
    {
      '@type': 'WebSite',
      '@id': 'https://ewastekochi.in/#website',
      url: 'https://ewastekochi.in/',
      name: 'EWaste Kochi',
      publisher: { '@id': 'https://ewastekochi.in/#organization' },
    },
    {
      '@type': 'WebPage',
      '@id': `${canonical}#webpage`,
      url: canonical,
      name: title,
      isPartOf: { '@id': 'https://ewastekochi.in/#website' },
      dateModified,
      inLanguage: 'en-IN',
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: breadcrumbs.map((crumb, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        name: crumb.name,
        item: crumb.url,
      })),
    },
    ...(faqSchema ? [faqSchema] : []),
    ...(schema ? (Array.isArray(schema) ? schema : [schema]) : []),
  ],
};
---

<!DOCTYPE html>
<html lang="en-IN" itemscope itemtype="https://schema.org/WebPage">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">

  <!-- Primary SEO -->
  <title>{title}</title>
  <meta name="description" content={description}>
  <meta name="robots" content={noIndex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1'}>
  <meta name="author" content="EWaste Kochi">
  <link rel="canonical" href={canonical}>
  <link rel="sitemap" href="/sitemap-index.xml">

  <!-- Geo -->
  <meta name="geo.region" content="IN-KL">
  <meta name="geo.placename" content="Kochi, Ernakulam, Kerala, India">
  <meta name="geo.position" content="9.9390;76.3590">

  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:locale" content="en_IN">
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:url" content={canonical}>
  <meta property="og:site_name" content="EWaste Kochi">
  <meta property="og:image" content={ogImage}>
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:alt" content="EWaste Kochi - Certified E-Waste Recycling and ITAD Services Kerala">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:site" content="@ewastekochi">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={ogImage}>

  <!-- Preconnects & Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&family=Lora:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">

  <!-- Preload critical assets -->
  <link rel="preload" href="/assets/images/logo.webp" as="image" type="image/webp">

  <!-- Schema JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify(baseSchema)} />

  <slot name="head" />
</head>
<body>
  <slot />

  <!-- WhatsApp Float -->
  <div class="wa-float" role="complementary" aria-label="WhatsApp contact">
    <a href={contact.whatsappMessage} target="_blank" rel="noopener noreferrer" aria-label="Chat on WhatsApp">
      <span class="wa-icon" aria-hidden="true">💬</span>
      <span>WhatsApp Us</span>
    </a>
  </div>

  <style is:global>
    /* ══════════════════════════════════════════════
       GLOBAL DESIGN SYSTEM — EWaste Kochi 2026
    ══════════════════════════════════════════════ */
    :root {
      --bg: #050908;
      --surface: #080E0A;
      --card: #0B1410;
      --card2: #0F1A14;
      --border: #162018;
      --border2: #1E2E22;
      --green: #00E896;
      --green2: #00C07A;
      --green3: #007A50;
      --lime: #AAFF57;
      --amber: #F5A623;
      --red: #FF4757;
      --blue: #00B4FF;
      --white: #EBF5EF;
      --muted: #426052;
      --text: #8AB4A0;
      --font: 'Syne', sans-serif;
      --mono: 'JetBrains Mono', monospace;
      --serif: 'Lora', Georgia, serif;
      --radius: 12px;
      --radius-lg: 18px;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; font-size: 16px; }
    body { font-family: var(--font); background: var(--bg); color: var(--text); overflow-x: hidden; line-height: 1.65; }
    a { text-decoration: none; color: inherit; }
    img { max-width: 100%; display: block; }
    button { font-family: var(--font); cursor: pointer; }
    ::-webkit-scrollbar { width: 3px; }
    ::-webkit-scrollbar-track { background: var(--surface); }
    ::-webkit-scrollbar-thumb { background: var(--green3); border-radius: 2px; }
    ::selection { background: rgba(0,232,150,.18); color: var(--green); }

    /* Layout */
    .wrap { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
    .section { padding: 100px 0; }
    .section-alt { padding: 100px 0; background: var(--surface); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
    .section-tight { padding: 64px 0; }

    /* Typography */
    h1, h2, h3, h4, h5 { color: var(--white); line-height: 1.1; font-weight: 700; }
    .sec-eyebrow { display: inline-flex; align-items: center; gap: 10px; font-size: .68rem; font-weight: 700; letter-spacing: .2em; text-transform: uppercase; color: var(--green); margin-bottom: 16px; }
    .sec-eyebrow::before { content: ''; width: 28px; height: 1.5px; background: var(--green); }
    .sec-title { font-size: clamp(2rem, 4vw, 3.2rem); font-weight: 800; margin-bottom: .5rem; letter-spacing: -.03em; }
    .sec-title em { color: var(--green); font-style: normal; }
    .sec-sub { color: var(--muted); max-width: 560px; font-size: .95rem; line-height: 1.8; }
    .text-center { text-align: center; }
    .text-center .sec-sub { margin: 0 auto 3.5rem; }
    .text-green { color: var(--green); }

    /* Buttons */
    .btn { display: inline-flex; align-items: center; gap: 8px; border: none; cursor: pointer; font-family: var(--font); font-weight: 700; text-decoration: none; transition: all .22s cubic-bezier(.4,0,.2,1); font-size: .88rem; letter-spacing: .01em; border-radius: var(--radius); }
    .btn-primary { background: var(--green); color: #051008; padding: 14px 28px; box-shadow: 0 4px 24px rgba(0,232,150,.2); }
    .btn-primary:hover { background: var(--green2); transform: translateY(-2px); box-shadow: 0 8px 36px rgba(0,232,150,.32); }
    .btn-outline { background: transparent; border: 1.5px solid rgba(0,232,150,.4); color: var(--green); padding: 13px 26px; }
    .btn-outline:hover { background: rgba(0,232,150,.06); border-color: var(--green); transform: translateY(-1px); }
    .btn-wa { background: #25D366; color: #fff; padding: 14px 28px; box-shadow: 0 4px 20px rgba(37,211,102,.2); }
    .btn-wa:hover { background: #1fb855; transform: translateY(-2px); box-shadow: 0 8px 32px rgba(37,211,102,.32); }
    .btn-lg { padding: 16px 36px; font-size: .95rem; border-radius: 14px; }
    .btn-sm { padding: 9px 18px; font-size: .8rem; }

    /* Badges */
    .badge { display: inline-flex; align-items: center; font-size: .7rem; font-weight: 600; padding: 3px 9px; border-radius: 16px; }
    .badge-g { background: rgba(0,232,150,.1); color: var(--green); border: 1px solid rgba(0,232,150,.18); }
    .badge-a { background: rgba(245,166,35,.1); color: var(--amber); border: 1px solid rgba(245,166,35,.18); }
    .badge-b { background: rgba(0,180,255,.1); color: var(--blue); border: 1px solid rgba(0,180,255,.18); }
    .badge-r { background: rgba(255,71,87,.1); color: var(--red); border: 1px solid rgba(255,71,87,.18); }

    /* WhatsApp Float */
    .wa-float { position: fixed; bottom: 28px; right: 28px; z-index: 9999; }
    .wa-float a { display: flex; align-items: center; gap: 10px; background: #25D366; color: #fff; padding: 14px 20px; border-radius: 50px; font-size: .85rem; font-weight: 700; box-shadow: 0 8px 32px rgba(37,211,102,.4); transition: all .25s; }
    .wa-float a:hover { background: #1fb855; transform: translateY(-3px) scale(1.03); box-shadow: 0 12px 40px rgba(37,211,102,.5); }
    .wa-float .wa-icon { font-size: 1.4rem; }

    /* FAQ */
    .faq-list { display: flex; flex-direction: column; gap: 10px; max-width: 820px; margin: 0 auto; }
    .faq-item { background: var(--card); border: 1px solid var(--border); border-radius: 14px; overflow: hidden; transition: border-color .2s; }
    .faq-item.open { border-color: rgba(0,232,150,.22); }
    .faq-q { width: 100%; background: none; border: none; padding: 20px 24px; display: flex; align-items: center; justify-content: space-between; cursor: pointer; text-align: left; gap: 16px; }
    .faq-qt { font-size: .93rem; font-weight: 700; color: var(--white); flex: 1; }
    .faq-ic { width: 28px; height: 28px; border-radius: 8px; background: rgba(0,232,150,.09); border: 1px solid rgba(0,232,150,.18); display: flex; align-items: center; justify-content: center; color: var(--green); flex-shrink: 0; font-size: 1rem; transition: transform .25s; }
    .faq-item.open .faq-ic { transform: rotate(45deg); }
    .faq-a { max-height: 0; overflow: hidden; transition: max-height .38s ease; }
    .faq-item.open .faq-a { max-height: 400px; }
    .faq-at { padding: 0 24px 20px; font-size: .87rem; color: var(--text); line-height: 1.75; border-top: 1px solid var(--border); padding-top: 16px; font-family: var(--serif); }

    /* Responsive */
    @media (max-width: 768px) {
      .section { padding: 72px 0; }
      .section-alt { padding: 72px 0; }
      .wa-float a span:last-child { display: none; }
      .wa-float a { padding: 16px; border-radius: 50%; }
    }
  </style>

  <script>
    // FAQ accordion
    document.addEventListener('DOMContentLoaded', () => {
      document.querySelectorAll('.faq-q').forEach(btn => {
        btn.addEventListener('click', () => {
          const item = btn.closest('.faq-item');
          const isOpen = item.classList.contains('open');
          document.querySelectorAll('.faq-item.open').forEach(i => i.classList.remove('open'));
          if (!isOpen) item.classList.add('open');
        });
      });
    });
  </script>
</body>
</html>
